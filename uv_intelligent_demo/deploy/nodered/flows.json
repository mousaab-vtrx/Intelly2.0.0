[
    {
        "id": "uvflowtab001",
        "type": "tab",
        "label": "UV Replay Docker",
        "disabled": false,
        "info": "Replay simulation CSV to MQTT and InfluxDB in Docker."
    },
    {
        "id": "uvmqttbroker001",
        "type": "mqtt-broker",
        "name": "Mosquitto",
        "broker": "mosquitto",
        "port": "1883",
        "clientid": "",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "4",
        "keepalive": "60",
        "cleansession": true,
        "birthTopic": "",
        "birthQos": "0",
